DATABASE_URL=postgres://user:password@localhost:5432/rotary_db
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare R2 Storage
R2_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
R2_BUCKET_NAME=rotary
R2_ENDPOINT=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.cloudflarestorage.com
R2_REGION=auto
# Gunakan custom domain R2 untuk production, bukan Public Development URL r2.dev.
R2_PUBLIC_BASE_URL=https://assets.example.com

# Mapbox (autocomplete alamat listing + peta halaman detail)
# Public token (pk.*) dari https://console.mapbox.com — aman diekspos ke client
NEXT_PUBLIC_MAPBOX_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
